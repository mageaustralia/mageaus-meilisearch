<?php
/**
 * Meilisearch Autocomplete Search Box Template
 *
 * Visually identical to Maho's stock catalogsearch/form.mini.phtml so
 * the search box looks native (magnifier icon inside the input, no
 * standalone "Search" button) regardless of whether the Meilisearch
 * frontend is enabled.
 *
 * Crucially, this DOES NOT init Varien.searchForm.initAutocomplete()
 * the way Maho's stock template does - the Meilisearch JS bundle
 * attaches its own autocomplete to `#search` (or whatever selector the
 * admin configures), so leaving the native init in place would render
 * a second, conflicting dropdown alongside the Meili one.
 *
 * @var Mage_Core_Block_Template $this
 */

/** @var Mage_CatalogSearch_Helper_Data $catalogSearchHelper */
$catalogSearchHelper = $this->helper('catalogsearch');
?>
<form role="search" id="search_mini_form" action="<?= $catalogSearchHelper->getResultUrl() ?>" method="get">
    <div class="input-box">
        <label for="search"><?= $this->__('Search:') ?></label>
        <input id="search"
               type="search"
               name="<?= $catalogSearchHelper->getQueryParamName() ?>"
               value="<?= $catalogSearchHelper->getEscapedQueryText() ?>"
               class="input-text required-entry"
               maxlength="<?= $catalogSearchHelper->getMaxQueryLength() ?>"
               placeholder="<?= $this->quoteEscape($this->__('Search entire store here...')) ?>"
               autocomplete="off">
        <button type="submit"
                title="<?= $this->quoteEscape($this->__('Search')) ?>"
                class="button search-button"><?= $this->getIconSvg('search') ?></button>
    </div>

    <?php /*
        Intentionally NOT rendering #search_autocomplete or initialising
        Varien.searchForm here - Meilisearch's JS attaches its own
        dropdown via window.meilisearchConfig.autocomplete.selector.
        Including the native suggester would produce a second dropdown
        on every keystroke.
    */ ?>
</form>
